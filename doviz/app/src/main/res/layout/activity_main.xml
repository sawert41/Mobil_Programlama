<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF7FF">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/midLine"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.50" />

    <View
        android:id="@+id/leftPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#FFF7FF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/midLine" />

    <View
        android:id="@+id/rightPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#286D7A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/midLine"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/chfText"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:text="CHF"
        android:textSize="18sp"
        android:textColor="#555555"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="130dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/midLine" />

    <TextView
        android:id="@+id/usdText"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:text="USD"
        android:textSize="18sp"
        android:textColor="#555555"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/chfText"
        android:layout_marginTop="25dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/midLine" />

    <TextView
        android:id="@+id/jpyText"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:text="JPY"
        android:textSize="18sp"
        android:textColor="#555555"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/usdText"
        android:layout_marginTop="25dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/midLine" />

    <TextView
        android:id="@+id/tryText"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:text="TRY"
        android:textSize="18sp"
        android:textColor="#555555"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/jpyText"
        android:layout_marginTop="25dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/midLine" />

    <TextView
        android:id="@+id/cadText"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:text="CAD"
        android:textSize="18sp"
        android:textColor="#555555"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tryText"
        android:layout_marginTop="25dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/midLine" />

    <TextView
        android:id="@+id/chfRateText"
        android:layout_width="130dp"
        android:layout_height="40dp"
        android:text="-"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:background="#4F8B96"
        app:layout_constraintTop_toTopOf="@id/chfText"
        app:layout_constraintStart_toEndOf="@id/midLine"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/usdRateText"
        android:layout_width="130dp"
        android:layout_height="40dp"
        android:text="-"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:background="#4F8B96"
        app:layout_constraintTop_toTopOf="@id/usdText"
        app:layout_constraintStart_toEndOf="@id/midLine"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/jpyRateText"
        android:layout_width="130dp"
        android:layout_height="40dp"
        android:text="-"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:background="#4F8B96"
        app:layout_constraintTop_toTopOf="@id/jpyText"
        app:layout_constraintStart_toEndOf="@id/midLine"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tryRateText"
        android:layout_width="130dp"
        android:layout_height="40dp"
        android:text="-"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:background="#4F8B96"
        app:layout_constraintTop_toTopOf="@id/tryText"
        app:layout_constraintStart_toEndOf="@id/midLine"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/cadRateText"
        android:layout_width="130dp"
        android:layout_height="40dp"
        android:text="-"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:background="#4F8B96"
        app:layout_constraintTop_toTopOf="@id/cadText"
        app:layout_constraintStart_toEndOf="@id/midLine"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/button"
        android:layout_width="125dp"
        android:layout_height="50dp"
        android:text="GET RATES"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#6F4DBA"
        app:layout_constraintTop_toBottomOf="@id/cadText"
        android:layout_marginTop="45dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/midLine" />

</androidx.constraintlayout.widget.ConstraintLayout>