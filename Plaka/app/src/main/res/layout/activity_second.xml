<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F5FA">

    <TextView
        android:id="@+id/txtIl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Il"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:layout_marginTop="50dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtPlakaGosterilen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gosterilen Plaka"
        android:textSize="20sp"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/txtIl"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtPlakaGercek"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gercek Plaka"
        android:textSize="20sp"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/txtPlakaGosterilen"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtSonuc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sonuc"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/txtPlakaGercek"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnGeriDon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Geri Don"
        android:textColor="#FFFFFF"
        android:backgroundTint="#3949AB"
        android:layout_marginTop="35dp"
        app:layout_constraintTop_toBottomOf="@id/txtSonuc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>